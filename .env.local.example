# ─── EmailJS (free tier — 200 emails/month) ──────────────────────────────────
# Sign up at https://emailjs.com → My Account → API Keys

# Your EmailJS service ID (create a Gmail service)
NEXT_PUBLIC_EJS_SERVICE_ID=service_xxxxxxx

# Template ID for owner notification email
NEXT_PUBLIC_EJS_OWNER_TPL=template_xxxxxxx

# Template ID for client quote email
NEXT_PUBLIC_EJS_CLIENT_TPL=template_xxxxxxx

# Your EmailJS public key
NEXT_PUBLIC_EJS_PUBLIC_KEY=your_public_key_here

# ─── Owner contact ────────────────────────────────────────────────────────────
# Owner's email address (receives quote notifications)
NEXT_PUBLIC_OWNER_EMAIL=owner@greenedgema.com

# Owner's WhatsApp number (digits only, with country code)
NEXT_PUBLIC_OWNER_WHATSAPP=16175550182

# Owner SMS via carrier email gateway (FREE — delivers as text message)
# Verizon:  6175550182@vtext.com
# AT&T:     6175550182@txt.att.net
# T-Mobile: 6175550182@tmomail.net
# Sprint:   6175550182@messaging.sprintpcs.com
NEXT_PUBLIC_OWNER_SMS_EMAIL=6175550182@vtext.com
